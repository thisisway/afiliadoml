FROM node:20-alpine AS builder
RUN npm install -g pnpm@9.15.0
WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
RUN pnpm install --frozen-lockfile

COPY . .

# URL da API em build-time (Next.js NEXT_PUBLIC_* é estático)
ARG NEXT_PUBLIC_API_URL=http://localhost:3001
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

RUN pnpm --filter @central-afiliado/shared build
RUN pnpm --filter @central-afiliado/web build

# ─────────────────────────────────────────────
# standalone output é auto-suficiente: inclui node_modules mínimos sem symlinks
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

# Root package.json from the monorepo has "type":"module" which breaks
# Next.js standalone server.js (CommonJS). Replace it with a minimal one.
RUN echo '{"name":"web","version":"1.0.0"}' > package.json

EXPOSE 3000
CMD ["node", "apps/web/server.js"]
