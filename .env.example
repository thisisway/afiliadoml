# =============================================================================
# BANCO DE DADOS
# =============================================================================
POSTGRES_USER=afiliado
POSTGRES_PASSWORD=afiliado_secret
POSTGRES_DB=central_afiliado
POSTGRES_PORT=5432
DATABASE_URL="postgresql://afiliado:afiliado_secret@localhost:5432/central_afiliado"

# =============================================================================
# REDIS
# =============================================================================
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379
REDIS_URL="redis://:redis_secret@localhost:6379"

# =============================================================================
# API
# =============================================================================
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# JWT — gere um segredo forte em produção: openssl rand -base64 64
JWT_SECRET=troque_por_segredo_forte_em_producao
JWT_EXPIRES_IN=7d

# =============================================================================
# FRONTEND
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3001

# API_URL is used server-side by the Next.js proxy to reach Fastify.
# In EasyPanel: set to http://afiliadoml:3001 (Docker internal service name).
# Locally: leave unset (falls back to NEXT_PUBLIC_API_URL above).
API_URL=

# =============================================================================
# MERCADO LIVRE — API OAuth (necessário para buscar produtos)
# Crie um app em: https://developers.mercadolivre.com.br/pt_br/registre-se
# Também pode ser configurado pela tela de Configurações do sistema
# =============================================================================
ML_APP_ID=
ML_SECRET_KEY=

# =============================================================================
# OPENAI (geração de copy com IA)
# Também pode ser configurado pela tela de Configurações do sistema
# =============================================================================
OPENAI_API_KEY=sk-...

# =============================================================================
# ENCURTADOR DE LINKS
# =============================================================================
# URL pública do sistema — usada para gerar links curtos
SHORT_LINK_BASE_URL=http://localhost:3001
